# =============================================================================
# Ascendra — Root Environment Variables Example
#
# Copy to .env and fill in real values before running locally.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-64-character-string-in-production
DEBUG=true

# ---------------------------------------------------------------------------
# Database URLs — one per service (each maps to a separate DB in Postgres)
# In local dev, each service has its own port (5432-5444).
# In Docker Compose, services address each other by container hostname.
# ---------------------------------------------------------------------------
AUTH_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5432/auth_db
LEARNING_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5433/learning_db
ASSESSMENT_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5434/assessment_db
COMMUNITY_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5435/community_db
GUILD_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5436/guild_db
MENTOR_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5437/mentor_db
MARKETPLACE_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5438/marketplace_db
PAYMENT_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5439/payment_db
BLOCKCHAIN_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5440/blockchain_db
AI_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5441/ai_db
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5442/notification_db
ANALYTICS_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5443/analytics_db
ECONOMY_CORE_DATABASE_URL=postgresql+asyncpg://ascendra:ascendra@localhost:5444/economy_core_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# ---------------------------------------------------------------------------
# OpenAI / Azure OpenAI (ai-service)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Uncomment for Azure:
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ---------------------------------------------------------------------------
# Stripe (payment-service)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# GCash / Maya (payment-service — Philippine payment providers)
# ---------------------------------------------------------------------------
GCASH_API_KEY=
MAYA_API_KEY=
MAYA_SECRET_KEY=

# ---------------------------------------------------------------------------
# Aptos / Blockchain (blockchain-service)
# ---------------------------------------------------------------------------
APTOS_NODE_URL=https://fullnode.devnet.aptoslabs.com/v1
APTOS_PRIVATE_KEY=0x...
APTOS_MODULE_ADDRESS=0x...

# ---------------------------------------------------------------------------
# Firebase (notification-service — push notifications)
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS_JSON=./firebase-service-account.json

# ---------------------------------------------------------------------------
# Email / SMTP (notification-service)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ascendra.io

# ---------------------------------------------------------------------------
# Judge0 (assessment-service — code execution sandbox)
# ---------------------------------------------------------------------------
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key

# ---------------------------------------------------------------------------
# Cloudflare R2 (object storage)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ascendra-assets
R2_PUBLIC_URL=https://assets.ascendra.io

# ---------------------------------------------------------------------------
# Next.js Frontend (NEXT_PUBLIC_* is exposed to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8011
NEXT_PUBLIC_APP_NAME=Ascendra
